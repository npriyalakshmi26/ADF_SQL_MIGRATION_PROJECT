								"sqlReaderQuery": {
									"value": "SELECT MAX(@{pipeline().parameters.WatermarkCoulumn}) AS MaxValue\nFROM @{pipeline().parameters.TableSchema}.@{pipeline().parameters.TableName}\n",
									"type": "Expression"
								},
								"queryTimeout": "02:00:00",
								"partitionOption": "None"
							},
							"dataset": {
								"referenceName": "DS_SQLSERVER_LKUP_MAXVALUE",
